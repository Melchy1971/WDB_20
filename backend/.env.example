APP_NAME=mail-knowledge-platform-backend
APP_ENV=development
APP_DEBUG=true
API_HOST=127.0.0.1
API_PORT=8000

# Neo4j connection (choose ONE variant below)
# Variant A: Neo4j Aura (recommended TLS)
# NEO4J_URI=neo4j+s://<your-aura-id>.databases.neo4j.io

# Variant B: Self-managed Neo4j
# NEO4J_URI=neo4j://<your-neo4j-host>:7687
# NEO4J_URI=neo4j+ssc://<your-neo4j-host>:7687

NEO4J_URI=neo4j://your-neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HEALTH_PATH=/api/tags
